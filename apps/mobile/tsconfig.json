{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "baseUrl": "../..",
    "paths": {
      "@vm/shared": ["packages/shared/src/index.ts"],
      "@vm/integration": ["packages/integration/src/index.ts"],
      "@vm/graphics": ["packages/graphics/src/index.ts"]
    }
  },
  "include": [
    "App.tsx",
    "src/**/*",
    "../../packages/shared/src/**/*",
    "../../packages/integration/src/**/*"
  ]
}
