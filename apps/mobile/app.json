{
  "expo": {
    "name": "VisualMath",
    "slug": "visualmath-mobile",
    "scheme": "visualmath",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
