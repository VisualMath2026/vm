{
  "name": "visualmath",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "pnpm -r run typecheck",
    "build": "pnpm --filter @vm/shared build && pnpm --filter @vm/integration build && pnpm --filter @vm/graphics build && pnpm --filter @vm/server-mock build && pnpm --filter @vm/mobile run typecheck",
    "dev:mobile": "pnpm --filter @vm/mobile start",
    "dev:server": "pnpm --filter @vm/server-mock dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.18.1",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "http-proxy": "^1.18.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.46.1"
  }
}